{
  "name": "autonomous-cloud-business-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled --port 8787",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply business_automation --local",
    "db:migrate:prod": "wrangler d1 migrations apply business_automation --remote",
    "ai:review": "node scripts/ai-review.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260514.0",
    "@playwright/test": "^1.52.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "wait-on": "^8.0.3",
    "wrangler": "^4.16.0"
  }
}
